// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String       @id @default(uuid())
  name      String
  email     String       @unique
  password  String
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  passwordResetRequestedAt    DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime? 
}

model InsuranceCompany {
  id        String   @id @default(uuid())
  name      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  products  Products[]
}

model ProductType {
  id        String   @id 
  name      String   @unique
  description String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  products  Products[] //remove products relation later
}

model Products {
  id                 String   @id 
  name               String
  productTypeId      String
  productType        ProductType @relation(fields: [productTypeId], references: [id])
  insuranceCompanyId String
  insuranceCompany   InsuranceCompany @relation(fields: [insuranceCompanyId], references: [id])
  clients            Client[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  visits Visit[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  cpf       String?  @unique
  cnpj      String?  @unique
  phoneNumber      String
  birthDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  products   Products[]
  address   Address?

  visits Visit[]
}

model Address {
  id          String   @id @default(uuid())
  cep     String?
  street      String
  district    String
  state       String
  city        String
  number      String
  complement  String?
  clientId    String   @unique
  client      Client   @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model ChartType {
  id          String   @id
  name        String   @unique
  description String
  size        String   @default("4x4")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  charts      Chart[]
}

model Chart {
  id          String   @id
  name        String   @unique
  description String?
  apiRoute    String
  order       Int
  unit        String?
  chartTypeId String
  chartType   ChartType @relation(fields: [chartTypeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Visit {
  id        String   @id
  name      String
  description String 
  clientId  String
  client    Client @relation(fields: [clientId], references: [id])
  productId String
  product   Products @relation(fields: [productId], references: [id])
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}